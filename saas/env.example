# Supabase Configuration
# Copia este archivo a .env.local y reemplaza con tus valores reales

# Base de datos para Prisma (recomendado en dev)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=30"

# URL de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-project-ref.supabase.co

# Clave pública/anónima de tu proyecto
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=tu-anon-key-aqui

# Access Token para MCP (opcional, para funcionalidades avanzadas)
SUPABASE_ACCESS_TOKEN=tu-access-token-aqui

# Demo Configuration
# Habilitar/deshabilitar el sistema de datos demo
ENABLE_DEMO_SEEDING=true

# Nota: Las variables que empiezan con NEXT_PUBLIC_ son visibles en el cliente
# Las demás son solo para el servidor

# Resend (opcional)
# Solo permite enviar correos a estos destinatarios en entornos de prueba
RESEND_ALLOWED_RECIPIENTS=mi-email@dominio.com,otro@dominio.com




